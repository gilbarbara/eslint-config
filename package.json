{
  "name": "@gilbarbara/eslint-config",
  "version": "1.1.0",
  "description": "Opinionated ESLint configuration for modern projects",
  "author": "Gil Barbara <gilbarbara@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gilbarbara/eslint-config.git"
  },
  "bugs": {
    "url": "https://github.com/gilbarbara/eslint-config/issues"
  },
  "homepage": "https://github.com/gilbarbara/eslint-config",
  "type": "module",
  "main": "src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./base": "./src/base.js",
    "./node": "./src/node.js",
    "./react": "./src/react.js",
    "./testing-library": "./src/testing-library.js",
    "./type-checking": "./src/type-checking.js",
    "./vitest": "./src/vitest.js"
  },
  "files": [
    "src"
  ],
  "keywords": [
    "eslint",
    "config",
    "javascript",
    "typescript",
    "react"
  ],
  "license": "MIT",
  "peerDependencies": {
    "eslint": "9",
    "prettier": "3",
    "typescript": "5 || 6",
    "vitest": "3 || 4"
  },
  "peerDependenciesMeta": {
    "vitest": {
      "optional": true
    }
  },
  "dependencies": {
    "@babel/core": "^7.29.0",
    "@babel/eslint-parser": "^7.28.6",
    "@babel/eslint-plugin": "^7.27.1",
    "@babel/preset-react": "^7.28.5",
    "@eslint/compat": "^2.0.3",
    "@vitest/eslint-plugin": "^1.6.13",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-perfectionist": "^5.7.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-compiler": "^19.1.0-rc.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-regexp": "^3.1.0",
    "eslint-plugin-sort-destructure-keys": "^3.0.0",
    "eslint-plugin-testing-library": "^7.16.2",
    "eslint-plugin-unicorn": "^63.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.4.0",
    "typescript-eslint": "^8.57.2"
  },
  "devDependencies": {
    "@gilbarbara/prettier-config": "^1.0.0",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@vitest/coverage-v8": "^4.1.1",
    "eslint": "^9.39.4",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "prop-types": "^15.8.1",
    "react": "^19.2.4",
    "repo-tools": "^0.3.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.1"
  },
  "scripts": {
    "lint": "eslint --fix src test",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest watch",
    "validate": "pnpm run lint && pnpm run test:coverage",
    "prepare": "husky"
  },
  "prettier": "@gilbarbara/prettier-config",
  "pnpm": {
    "overrides": {
      "eslint-plugin-react-hooks>zod-validation-error": "^4.0.0"
    }
  }
}
